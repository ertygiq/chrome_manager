#!/usr/bin/env ruby
# frozen_string_literal: true

require 'json'
begin
  ENV['BUNDLE_GEMFILE'] ||= File.expand_path('../Gemfile', __dir__)
  require 'bundler/setup'
rescue LoadError
end
require_relative '../lib/chrome_manager'

cmd = ARGV.shift || 'help'
manager = ChromeManager.new

begin
  result = case cmd
           when 'lease'
             unknown = ARGV - ['--connect-agent-browser']
             raise "unknown option(s) for lease: #{unknown.join(' ')}" unless unknown.empty?

             lease = manager.lease
             manager.connect_agent_browser(lease.fetch('id')) if ARGV.include?('--connect-agent-browser')
             lease
           when 'list'
             raise "usage: chrome-manager list" unless ARGV.empty?

             manager.list
           when 'release'
             raise 'usage: chrome-manager release <id|session|port>' unless ARGV.size == 1

             manager.release(ARGV.fetch(0))
           when 'gc'
             raise "usage: chrome-manager gc" unless ARGV.empty?

             manager.gc
           when 'check'
             raise 'usage: chrome-manager check <id|session|port>' unless ARGV.size == 1

             manager.check(ARGV.fetch(0))
           when 'connect-agent-browser'
             raise 'usage: chrome-manager connect-agent-browser <id|session|port>' unless ARGV.size == 1

             manager.connect_agent_browser(ARGV.fetch(0))
           when 'help', '--help', '-h'
             puts <<~HELP
               Usage: chrome-manager <command>

               Commands:
                 lease [--connect-agent-browser]
                                          Launch visible Chrome and return lease JSON
                 list                     List active leases
                 check <id|session|port>  Verify agent-browser CDP points at lease port
                 connect-agent-browser <id|session|port>
                                          Connect/reconnect agent-browser to leased Chrome
                 release <id|session|port> Stop Chrome and remove lease
                 gc                       Remove dead leases

               Agent usage:
                 chrome-manager lease --connect-agent-browser
                 agent-browser --session <session_id> open https://example.com
                 agent-browser --session <session_id> snapshot
                 ...
                 chrome-manager release <session_id>
             HELP
             exit 0
           else
             raise "unknown command: #{cmd}"
           end

  puts JSON.pretty_generate(result)
rescue StandardError => e
  warn "chrome-manager: #{e.message}"
  exit 1
end
